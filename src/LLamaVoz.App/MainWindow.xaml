<Window x:Class="LLamaVoz.DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLamaVoz — Panel"
        Width="440" Height="720"
        Background="#FF12121B"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF232336" Offset="0"/>
                        <GradientStop Color="#FF1C1C2B" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatNumber" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9AB0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="6,0,6,10">
            <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,10,0" VerticalAlignment="Center">
                <Border.Background>
                    <ImageBrush x:Name="LogoBrush" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
            <TextBlock Text="LLamaVoz" Foreground="White" FontSize="22" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Border DockPanel.Dock="Right" HorizontalAlignment="Right" CornerRadius="12"
                    Background="#FF2E2E44" Padding="12,5" VerticalAlignment="Center">
                <TextBlock x:Name="StateChip" Text="En espera" Foreground="#FF8AE0FF"
                           FontSize="13" FontWeight="SemiBold"/>
            </Border>
        </DockPanel>

        <!-- Stats: today -->
        <UniformGrid Grid.Row="1" Columns="2">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="TodayWords" Text="0" Style="{StaticResource StatNumber}"/>
                    <TextBlock Text="palabras hoy" Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="TodayDictations" Text="0" Style="{StaticResource StatNumber}"/>
                    <TextBlock Text="dictados hoy" Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Stats: totals -->
        <UniformGrid Grid.Row="2" Columns="2">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="TotalWords" Text="0" Style="{StaticResource StatNumber}" FontSize="22"/>
                    <TextBlock Text="palabras en total" Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="AvgWords" Text="0" Style="{StaticResource StatNumber}" FontSize="22"/>
                    <TextBlock Text="palabras por dictado" Style="{StaticResource StatLabel}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Last dictation -->
        <Border Grid.Row="3" Style="{StaticResource StatCard}" Margin="6,6,6,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ÚLTIMO DICTADO (solo en memoria, no se guarda)"
                           Style="{StaticResource StatLabel}" Margin="0,0,0,6"/>
                <TextBlock DockPanel.Dock="Bottom" x:Name="LastMeta" Text="—"
                           Style="{StaticResource StatLabel}" Margin="0,8,0,0"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LastText" Text="Aún no has dictado nada. Mantén Ctrl+Alt y habla, o toca Win+Alt."
                               Foreground="#FFE8E8F2" FontSize="14" TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Hotkey reference + language selector -->
        <Border Grid.Row="4" Style="{StaticResource StatCard}">
            <StackPanel>
                <TextBlock Text="IDIOMA DE TRANSCRIPCIÓN" Style="{StaticResource StatLabel}" Margin="0,0,0,4"/>
                <ComboBox x:Name="LanguageSelector" Height="30" Margin="0,0,0,10"
                          SelectionChanged="OnLanguageChanged"/>
                <TextBlock x:Name="LanguageHint" Style="{StaticResource StatLabel}" Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Text="Con un idioma fijo, el motor transcribe solo en ese idioma (nunca traduce). AUTO detecta el idioma en cada dictado."/>
                <TextBlock Text="VELOCIDAD / CALIDAD" Style="{StaticResource StatLabel}" Margin="0,0,0,4"/>
                <ComboBox x:Name="QualitySelector" Height="30" Margin="0,0,0,10"
                          SelectionChanged="OnQualityChanged"/>
                <TextBlock Text="ATAJOS" Style="{StaticResource StatLabel}" Margin="0,0,0,4"/>
                <UniformGrid Columns="2" Margin="0,0,0,8">
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock Text="Mantener para hablar" Style="{StaticResource StatLabel}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="PttSelector" Height="28" SelectionChanged="OnPttHotkeyChanged"/>
                    </StackPanel>
                    <StackPanel Margin="6,0,0,0">
                        <TextBlock Text="Toque para alternar" Style="{StaticResource StatLabel}" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ToggleSelector" Height="28" SelectionChanged="OnToggleHotkeyChanged"/>
                    </StackPanel>
                </UniformGrid>
                <TextBlock x:Name="HotkeysText" Foreground="#FFCECEE0" FontSize="13" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="6,8,6,0">
            <Button x:Name="HideButton" Content="Ocultar" Width="90" Height="30" Margin="0,0,8,0"
                    Background="#FF2E2E44" Foreground="White" BorderThickness="0" Click="OnHideClick"/>
            <Button x:Name="ExitButton" Content="Salir" Width="90" Height="30"
                    Background="#FF44283A" Foreground="White" BorderThickness="0" Click="OnExitClick"/>
        </StackPanel>

        <!-- Credit -->
        <TextBlock Grid.Row="6" Text="Created by Thomas Freund." HorizontalAlignment="Center"
                   Foreground="#FF6E6E86" FontSize="11" Margin="0,12,0,0"/>
    </Grid>
</Window>

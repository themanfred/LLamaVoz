<Window x:Class="LLamaVoz.DesktopApp.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLamaVoz"
        SizeToContent="Width" Height="60"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        Focusable="False" ResizeMode="NoResize">
    <Border x:Name="Pill" CornerRadius="21" Padding="8,0" Margin="6" Height="46"
            MinWidth="40" VerticalAlignment="Bottom"
            BorderThickness="1" BorderBrush="#2EFFFFFF"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="PillSlide" Y="0"/>
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F2262638" Offset="0"/>
                <GradientStop Color="#F215151F" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel x:Name="PillContent" Orientation="Horizontal" VerticalAlignment="Center" Height="42">
            <!-- Pulsing REC dot (visible while listening) -->
            <Ellipse x:Name="RecDot" Width="8" Height="8"
                     Fill="#FFFF5A6E" VerticalAlignment="Center" Margin="6,0,2,0"/>

            <!-- Language chip: click cycles the transcription language -->
            <Border x:Name="LangChip" CornerRadius="13" Background="#33FFFFFF"
                    VerticalAlignment="Center" Padding="10,4" Margin="4,0"
                    Cursor="Hand" MouseLeftButtonUp="OnLangChipClick"
                    ToolTip="Cambiar idioma de transcripción">
                <TextBlock x:Name="LangText" Text="AUTO" Foreground="White"
                           FontSize="11" FontWeight="SemiBold"/>
            </Border>

            <!-- Mic button: click starts/stops a toggle dictation -->
            <Border x:Name="MicButton" CornerRadius="14" Background="Transparent"
                    VerticalAlignment="Center" Padding="8,4" Margin="0,0,2,0"
                    Cursor="Hand" MouseLeftButtonUp="OnMicClick">
                <TextBlock x:Name="MicIcon" FontFamily="Segoe MDL2 Assets" Text="&#xE720;"
                           FontSize="15" Foreground="#FF8AE0FF" VerticalAlignment="Center"/>
            </Border>

            <!-- Level bars, generated in code (symmetric equalizer) -->
            <StackPanel x:Name="BarsPanel" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="6,0"/>

            <!-- Status text -->
            <TextBlock x:Name="StatusText" Text=""
                       Foreground="White" FontSize="13" VerticalAlignment="Center"
                       Margin="4,0,8,0" MaxWidth="420" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
    </Border>
</Window>
